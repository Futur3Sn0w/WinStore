{
  "id": "youtube-music",
  "name": "YouTube Music",
  "description": "Stream music, videos, and podcasts from YouTube's catalog. Get personalized recommendations, browse charts, and access your library across devices.",
  "publisher": "Google LLC",
  "version": "1.0.0",
  "icon": "mif-music",
  "color": "grey",
  "category": "music",
  "type": "modern",
  "size": "normal",
  "webview": {
    "enabled": true,
    "url": "https://music.youtube.com",
    "partition": "persist:youtube-music"
  },
  "requirements": {
    "installMode": "remote",
    "internet": true,
    "minVersion": "1.0"
  },
  "windowOptions": {
    "minimizable": true,
    "showIcon": true
  },
  "tileOptions": {
    "allowWide": false,
    "allowLarge": false
  },
  "files": [
    "resources/logo.svg",
    "resources/logo.png"
  ]
}