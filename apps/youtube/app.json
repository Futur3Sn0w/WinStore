{
  "id": "youtube",
  "name": "YouTube",
  "description": "Watch videos, browse Shorts, and manage your subscriptions with the YouTube app. Features a custom bottom navigation bar for quick access to Home, Shorts, Subscriptions, and Library.",
  "version": "1.0.0",
  "color": "red",
  "category": "video",
  "type": "modern",
  "size": "normal",
  "entryPoint": "index.html",
  "loadDirect": true,
  "requirements": {
    "installMode": "local",
    "internet": true,
    "minVersion": "1.0"
  },
  "windowOptions": {
    "minimizable": true,
    "showIcon": true
  },
  "tileOptions": {
    "allowWide": true,
    "allowLarge": true
  },
  "files": [
    "index.html",
    "youtube.js",
    "resources/logo.png",
    "resources/tiletiny.scale-80.png",
    "resources/tiletiny.scale-100.png",
    "resources/tilesmall.scale-80.png",
    "resources/tilesmall.scale-100.png",
    "resources/tilewide.scale-80.png",
    "resources/tilewide.scale-100.png",
    "resources/tilelarge.scale-80.png",
    "resources/tilelarge.scale-100.png"
  ]
}
